{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://openlamb.dev/schemas/task-envelope.json",
  "title": "TaskEnvelope",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "instruction",
    "user_goal",
    "requested_outputs",
    "source_entities",
    "target_entities",
    "time_constraints",
    "risk_level",
    "needs_confirmation",
    "primary_domain",
    "secondary_domains",
    "success_criteria"
  ],
  "properties": {
    "instruction": {
      "type": "string",
      "minLength": 1
    },
    "user_goal": {
      "type": "string",
      "minLength": 1
    },
    "requested_outputs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/requestedOutput"
      }
    },
    "source_entities": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/entityRef"
      }
    },
    "target_entities": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/entityRef"
      }
    },
    "time_constraints": {
      "$ref": "#/$defs/timeConstraints"
    },
    "risk_level": {
      "type": "string",
      "enum": ["low", "medium", "high"]
    },
    "needs_confirmation": {
      "type": "boolean"
    },
    "primary_domain": {
      "$ref": "#/$defs/domain"
    },
    "secondary_domains": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/domain"
      },
      "uniqueItems": true
    },
    "success_criteria": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  },
  "$defs": {
    "domain": {
      "type": "string",
      "enum": [
        "email",
        "calendar",
        "filesystem",
        "spreadsheet",
        "document",
        "browser_research",
        "browser_transaction",
        "code_repo",
        "shell_script",
        "presentation",
        "communication",
        "data_analysis"
      ]
    },
    "entityRef": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "value"],
      "properties": {
        "type": {
          "type": "string",
          "enum": [
            "email_account",
            "folder",
            "file",
            "spreadsheet",
            "document",
            "url",
            "inbox",
            "calendar",
            "repo",
            "query",
            "message",
            "dataset",
            "person",
            "organization",
            "other"
          ]
        },
        "value": {
          "type": "string",
          "minLength": 1
        },
        "locator": {
          "type": "string"
        }
      }
    },
    "requestedOutput": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "description"],
      "properties": {
        "type": {
          "type": "string",
          "enum": [
            "spreadsheet",
            "document",
            "presentation",
            "draft_reply",
            "email_send",
            "folder_update",
            "file_update",
            "report",
            "summary",
            "analysis",
            "other"
          ]
        },
        "description": {
          "type": "string",
          "minLength": 1
        },
        "required_fields": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "timeConstraints": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "relative_window": {
          "type": "string"
        },
        "start_time": {
          "type": "string",
          "format": "date-time"
        },
        "end_time": {
          "type": "string",
          "format": "date-time"
        },
        "timezone": {
          "type": "string"
        }
      }
    }
  }
}
