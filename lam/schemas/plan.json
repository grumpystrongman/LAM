{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://openlamb.dev/schemas/plan.json",
  "title": "Plan",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "task_id",
    "primary_domain",
    "secondary_domains",
    "validation_status",
    "steps"
  ],
  "properties": {
    "task_id": {
      "type": "string",
      "minLength": 1
    },
    "primary_domain": {
      "type": "string",
      "enum": [
        "email",
        "calendar",
        "filesystem",
        "spreadsheet",
        "document",
        "browser_research",
        "browser_transaction",
        "code_repo",
        "shell_script",
        "presentation",
        "communication",
        "data_analysis"
      ]
    },
    "secondary_domains": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "uniqueItems": true
    },
    "validation_status": {
      "type": "string",
      "enum": ["pending", "valid", "invalid"]
    },
    "validation_errors": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "steps": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/step"
      }
    }
  },
  "$defs": {
    "step": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "index",
        "action",
        "tool_family",
        "target",
        "reason",
        "expected_output",
        "risk",
        "undo_strategy",
        "verification_check"
      ],
      "properties": {
        "index": {
          "type": "integer",
          "minimum": 0
        },
        "action": {
          "type": "string",
          "minLength": 1
        },
        "tool_family": {
          "type": "string",
          "enum": [
            "email",
            "calendar",
            "filesystem",
            "spreadsheet",
            "document",
            "browser",
            "repo",
            "shell",
            "presentation",
            "data_analysis"
          ]
        },
        "target": {
          "$ref": "#/$defs/nonEmptyTarget"
        },
        "reason": {
          "type": "string",
          "minLength": 1
        },
        "expected_output": {
          "type": "string",
          "minLength": 1
        },
        "risk": {
          "type": "string",
          "enum": ["low", "medium", "high"]
        },
        "undo_strategy": {
          "type": "string",
          "minLength": 1
        },
        "verification_check": {
          "type": "string",
          "minLength": 1
        },
        "requires_confirmation": {
          "type": "boolean",
          "default": false
        },
        "destructive": {
          "type": "boolean",
          "default": false
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "destructive": { "const": true }
            }
          },
          "then": {
            "properties": {
              "requires_confirmation": { "const": true }
            }
          }
        }
      ]
    },
    "nonEmptyTarget": {
      "oneOf": [
        {
          "type": "string",
          "minLength": 1
        },
        {
          "type": "object",
          "additionalProperties": false,
          "minProperties": 1,
          "properties": {
            "type": {
              "type": "string",
              "minLength": 1
            },
            "id": {
              "type": "string",
              "minLength": 1
            },
            "path": {
              "type": "string",
              "minLength": 1
            },
            "query": {
              "type": "string",
              "minLength": 1
            },
            "url": {
              "type": "string",
              "minLength": 1
            },
            "time_window": {
              "type": "string",
              "minLength": 1
            }
          }
        }
      ]
    }
  }
}
